@model diplom.Models.Course

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <h2>@Model.Title</h2>
    <p>@Model.Description</p>

    @if (Model.IsPremium)
    {
        <span class="badge bg-warning text-dark">Premium курс</span>
    }
    else
    {
        <span class="badge bg-success">Бесплатный курс</span>
    }


    @if (User.IsInRole("Admin"))
    {
        <div class="mt-3 d-flex gap-2">
            <a class="btn btn-primary"
               asp-controller="Course"
               asp-action="CreateModule"
               asp-route-courseId="@Model.Id">
                Добавить модуль
            </a>

            <a class="btn btn-outline-secondary"
               asp-controller="Course"
               asp-action="Edit"
               asp-route-id="@Model.Id">
                Редактировать курс
            </a>

            <a class="btn btn-outline-danger"
               asp-controller="Course"
               asp-action="Delete"
               asp-route-id="@Model.Id">
                Удалить курс
            </a>
        </div>
    }
</div>

@if (Model.Modules == null || !Model.Modules.Any())
{
    <p>В курсе пока нет модулей.</p>
}
else
{
    @foreach (var module in Model.Modules.OrderBy(m => m.OrderNumber))
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">@module.Title</h4>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0"></h4>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-outline-success"
                                   asp-controller="Course"
                                   asp-action="CreateLesson"
                                   asp-route-moduleId="@module.Id">
                                    Добавить урок
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="Course"
                                   asp-action="EditModule"
                                   asp-route-id="@module.Id">
                                    Редактировать модуль
                                </a>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-controller="Course"
                                   asp-action="DeleteModule"
                                   asp-route-id="@module.Id">
                                    Удалить модуль
                                </a>
                            </div>
                        }
                    </div>

                </div>

                @if (module.Lessons == null || !module.Lessons.Any())
                {
                    <p>В модуле пока нет уроков.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var lesson in module.Lessons.OrderBy(l => l.OrderNumber))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @lesson.Title
                                    @if (lesson.IsPreview)
                                    {
                                        <span class="badge bg-info text-dark ms-2">Preview</span>
                                    }
                                </span>

                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-controller="Course"
                                       asp-action="Lesson"
                                       asp-route-id="@lesson.Id">
                                        Открыть урок
                                    </a>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="btn btn-sm btn-outline-secondary"
                                           asp-controller="Course"
                                           asp-action="EditLesson"
                                           asp-route-id="@lesson.Id">
                                            Редактировать
                                        </a>

                                        <a class="btn btn-sm btn-outline-danger"
                                           asp-controller="Course"
                                           asp-action="DeleteLesson"
                                           asp-route-id="@lesson.Id">
                                            Удалить
                                        </a>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}

<a class="btn btn-secondary mt-3" asp-controller="Course" asp-action="Index">Назад к курсам</a>