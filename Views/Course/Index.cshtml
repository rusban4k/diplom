@model List<diplom.Models.Course>

@{
    ViewData["Title"] = "Курсы";
}

<h2 class="mb-4">Каталог курсов</h2>

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-primary mb-4" asp-controller="Course" asp-action="Create">
        Создать курс
    </a>
}

<div class="row g-4">
    @foreach (var course in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 course-card">
                <div class="card-body d-flex flex-column">

                    <h4>@course.Title</h4>

                    <p class="text-muted small">
                        @course.PreviewText
                    </p>

                    <div class="mt-auto">
                        @if (course.IsPremium)
                        {
                            <span class="badge bg-warning text-dark mb-2">Premium</span>
                        }
                        else
                        {
                            <span class="badge bg-success mb-2">Бесплатно</span>
                        }

                        <div>
                            <a class="btn btn-sm btn-outline-primary w-100"
                               asp-controller="Course"
                               asp-action="Details"
                               asp-route-id="@course.Id">
                                Открыть курс
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>