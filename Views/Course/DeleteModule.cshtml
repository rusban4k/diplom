@model diplom.Models.CourseModule

@{
    ViewData["Title"] = "Удаление модуля";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h2 class="mb-3">Удаление модуля</h2>

        <p>Вы действительно хотите удалить модуль?</p>

        <div class="mb-3">
            <strong>@Model.Title</strong>
        </div>

        <form asp-action="DeleteModule" asp-controller="Course" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Удалить</button>
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-secondary">Отмена</a>
        </form>
    </div>
</div>