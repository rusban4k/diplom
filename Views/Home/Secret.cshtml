@{
    ViewData["Title"] = "Личный раздел";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h2>Личный раздел</h2>

        <p>Вы успешно авторизованы в системе Sonic Legacy.</p>

        <ul>
            <li><strong>Email:</strong> @User.Identity?.Name</li>
            <li><strong>Авторизован:</strong> @User.Identity?.IsAuthenticated</li>
            <li><strong>Premium:</strong> @(User.IsInRole("Premium") ? "Да" : "Нет")</li>
            <li><strong>Admin:</strong> @(User.IsInRole("Admin") ? "Да" : "Нет")</li>
        </ul>
    </div>
</div>