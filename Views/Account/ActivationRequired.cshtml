@{
    ViewData["Title"] = "Активация аккаунта";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <h2 class="mb-3">Аккаунт создан</h2>

                <p class="mb-3">
                    Регистрация успешно завершена, но ваш аккаунт пока не активирован.
                </p>

                <p class="text-muted mb-4">
                    Для активации аккаунта напишите администратору платформы Sonic Legacy во ВКонтакте и укажите ваш email.
                </p>

                <a class="premium-cta"
                   href="https://vk.com/rusban4k"
                   target="_blank"
                   rel="noopener noreferrer">
                    <span class="contact-icon">💬</span>
                    Написать администратору
                </a>

                <div class="mt-4">
                    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
                        На главную
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>